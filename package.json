{
  "name": "react-native-fitness-geolocation",
  "version": "2.1.0",
  "description": "React Native fitness GPS — background activity tracking, native SQLite persistence, motion auto-pause. Drop-in geolocation for Strava-class apps.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "ios",
    "android",
    "docs",
    "scripts",
    "react-native.config.js",
    "FitnessGeolocation.podspec",
    "AGENTS.md",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "prepare": "node scripts/ensure-lib.js",
    "prepublishOnly": "yarn bob build",
    "typescript": "tsc --noEmit",
    "verify-setup": "node scripts/verify-setup.js"
  },
  "keywords": [
    "react-native",
    "react-native-geolocation",
    "react-native-fitness",
    "react-native-gps",
    "react-native-background-geolocation",
    "background-location",
    "fitness-tracking",
    "activity-tracking",
    "gps-tracker",
    "workout-tracker",
    "running-app",
    "cycling-app",
    "corelocation",
    "sqlite",
    "native-module"
  ],
  "author": "Arslan Khan (https://github.com/Arslankhan9000)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arslankhan9000/react-native-fitness-geolocation.git"
  },
  "bugs": {
    "url": "https://github.com/Arslankhan9000/react-native-fitness-geolocation/issues"
  },
  "homepage": "https://github.com/Arslankhan9000/react-native-fitness-geolocation#readme",
  "bin": "scripts/verify-setup.js",
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.73.0"
  },
  "devDependencies": {
    "react": "19.0.0",
    "react-native": "0.79.7",
    "react-native-builder-bob": "^0.40.6",
    "typescript": "^5.0.4"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "packageManager": "yarn@4.15.0+sha512.07ec708ac11e2eaa4ea2b04cfbb272812f7e74a753f1595eaef4486c663a98306a30cca3e6fc40f7a0b168dcfb3a2490b6a5e0501e20fb69cc36f563dd161c53"
}
